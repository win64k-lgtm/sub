# Copie para .env e ajuste os valores
# Para testar com o PostgreSQL do Railway (remoto), use os valores abaixo.
# Para testar com PostgreSQL instalado na sua máquina, use localhost.

# Banco no Railway (já configurado no código como fallback)
PGHOST=tramway.proxy.rlwy.net
PGPORT=55414
PGUSER=postgres
PGPASSWORD=sua_senha_aqui
PGDATABASE=railway

# Banco local (descomente e use se tiver PostgreSQL instalado na sua máquina)
# PGHOST=127.0.0.1
# PGPORT=5432
# PGUSER=postgres
# PGPASSWORD=sua_senha_local
# PGDATABASE=railway
# PGSSLMODE=disable
